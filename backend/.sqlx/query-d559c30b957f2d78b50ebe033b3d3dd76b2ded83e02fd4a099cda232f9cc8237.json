{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.id, a.slug, a.display_name, a.account_type, m.role, a.created_at\n        FROM accounts a\n        JOIN account_memberships m ON m.account_id = a.id\n        WHERE a.slug = $1 AND m.user_id = $2\n        LIMIT 1\n        ",
