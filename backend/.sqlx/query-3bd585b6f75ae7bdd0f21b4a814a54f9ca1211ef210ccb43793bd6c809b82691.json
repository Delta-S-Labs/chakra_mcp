  "query": "\n        SELECT i.id, i.account_id, i.email, i.role, i.expires_at, i.accepted_at,\n               a.slug, a.display_name, a.account_type, a.created_at\n        FROM account_invites i\n        JOIN accounts a ON a.id = i.account_id\n        WHERE i.token_hash = $1\n        FOR UPDATE\n        ",
