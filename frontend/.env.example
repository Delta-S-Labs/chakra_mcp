# Frontend environment template.
#
# Copy to `frontend/.env.local` (gitignored) and fill in. Next.js
# reads .env files from this directory (where next.config.ts lives),
# NOT from the repo root.
#
# Backend / AI / tooling secrets live in the repo-root .env.local —
# see ../.env.example.

# ─── NextAuth (Auth.js v5) ───
# Where the app is reachable from. Set to your domain in production.
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
# v5 reads AUTH_SECRET; we set both for parity with v4 docs.
NEXTAUTH_SECRET=
AUTH_SECRET=

# ─── GitHub OAuth ───
# Register an app at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Google OAuth ───
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── reCAPTCHA v2 (challenge) ───
# Get keys at https://www.google.com/recaptcha/admin
# Disable for private deployments that don't need it.
CAPTCHA_ENABLED=true
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Public mirror of the site key — Next.js exposes only NEXT_PUBLIC_*
# vars to the browser, so we duplicate the site key here as well.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
