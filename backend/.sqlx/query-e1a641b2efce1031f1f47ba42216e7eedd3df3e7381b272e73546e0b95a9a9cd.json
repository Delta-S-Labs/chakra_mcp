  "query": "\n        SELECT i.email, i.role, i.expires_at, i.accepted_at, a.slug, a.display_name\n        FROM account_invites i\n        JOIN accounts a ON a.id = i.account_id\n        WHERE i.token_hash = $1\n        LIMIT 1\n        ",
