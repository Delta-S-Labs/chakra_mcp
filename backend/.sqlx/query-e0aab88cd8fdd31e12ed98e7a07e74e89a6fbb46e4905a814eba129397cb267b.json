{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.id, a.slug, a.display_name, a.account_type, m.role, a.created_at\n        FROM account_memberships m\n        JOIN accounts a ON a.id = m.account_id\n        WHERE m.user_id = $1\n        ORDER BY a.account_type DESC, a.created_at ASC\n        ",
