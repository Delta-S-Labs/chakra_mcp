# ChakraMCP — environment template.
#
# Copy this file to `.env.local` (gitignored) and fill in your values.
# Both .env and .env.local are excluded from git via .gitignore.
#
#   cp .env.example .env.local
#
# Variables marked OPTIONAL can be left as-is; they enable specific
# features (Bedrock support, captcha, etc.) but the relay runs without
# them. Variables marked REQUIRED are needed for the corresponding
# feature to work.

# ─────────────────────────────────────────────────────────────────────
# AI providers — for the example agents under examples/
# ─────────────────────────────────────────────────────────────────────

# NVIDIA NIM — free models at https://build.nvidia.com/
# Get a key: sign in at build.nvidia.com → API tab → Generate.
# OPTIONAL but recommended (free tier, broad model selection).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# AWS Bedrock — for the example agents (Claude on Bedrock, Llama, etc.)
# OPTIONAL. Configure if you want Bedrock-backed example agents.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# OR use a profile from ~/.aws/credentials
# AWS_PROFILE=default

# Anthropic API — direct access (alternative to Bedrock).
# OPTIONAL.
ANTHROPIC_API_KEY=

# OpenAI — alternative provider for the example agents.
# OPTIONAL.
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Relay backend — Rust + Postgres (Phase 1, not yet scaffolded)
# ─────────────────────────────────────────────────────────────────────

# Postgres connection string for the local relay.
# REQUIRED when running the backend.
DATABASE_URL=postgres://chakramcp:chakramcp@localhost:5432/chakramcp

# JWT signing secret. Generate with: openssl rand -hex 32
# REQUIRED.
JWT_SECRET=

# Webhook signing secret (HMAC-SHA256). Generate the same way.
# REQUIRED.
WEBHOOK_SIGNING_SECRET=

# Port for the relay HTTP server.
PORT=8080

# Logging filter. See https://docs.rs/tracing-subscriber/.
RUST_LOG=info,chakramcp_network=debug

# ─────────────────────────────────────────────────────────────────────
# Relay web app — frontend auth (NextAuth.js)
# ─────────────────────────────────────────────────────────────────────

# Generate with: openssl rand -base64 32
# REQUIRED for the relay web app.
NEXTAUTH_SECRET=

# Where the app is reachable from. Set to your domain in production.
NEXTAUTH_URL=http://localhost:3000

# ─── GitHub OAuth ───
# Register an app at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
# REQUIRED for GitHub sign-in.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Google OAuth ───
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# REQUIRED for Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── reCAPTCHA v2 (challenge) ───
# Get keys at https://www.google.com/recaptcha/admin
# OPTIONAL — set CAPTCHA_ENABLED=false for private deployments that
# don't need it.
CAPTCHA_ENABLED=true
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────
# Observability (production)
# ─────────────────────────────────────────────────────────────────────

# Sentry DSN for error reporting.
# OPTIONAL.
SENTRY_DSN=

# OpenTelemetry collector endpoint.
# OPTIONAL.
OTEL_EXPORTER_OTLP_ENDPOINT=
