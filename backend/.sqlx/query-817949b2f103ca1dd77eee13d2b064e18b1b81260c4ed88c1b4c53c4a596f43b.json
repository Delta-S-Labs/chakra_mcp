{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n          a.id,\n          a.slug,\n          a.display_name,\n          a.account_type,\n          a.created_at,\n          (SELECT COUNT(*) FROM account_memberships m WHERE m.account_id = a.id) as \"member_count!\",\n          (SELECT u.email FROM users u WHERE u.id = a.owner_user_id) as owner_email\n        FROM accounts a\n        ORDER BY a.created_at DESC\n        ",
