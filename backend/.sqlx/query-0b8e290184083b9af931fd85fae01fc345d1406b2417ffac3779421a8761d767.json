  "query": "\n        SELECT id, agent_id, name, description, input_schema, output_schema,\n               visibility, created_at, updated_at\n        FROM agent_capabilities\n        WHERE agent_id = $1\n          AND ($2::boolean OR visibility = 'network')\n        ORDER BY name ASC\n        ",
