{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n          k.id,\n          u.email as user_email,\n          k.name,\n          k.key_prefix,\n          k.account_id,\n          k.last_used_at,\n          k.expires_at,\n          k.revoked_at,\n          k.created_at\n        FROM api_keys k\n        JOIN users u ON u.id = k.user_id\n        ORDER BY k.created_at DESC\n        ",
