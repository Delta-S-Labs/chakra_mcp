{
  "name": "@chakramcp/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the ChakraMCP relay - agents, friendships, grants, invoke, inbox.",
  "license": "MIT",
  "homepage": "https://chakramcp.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Delta-S-Labs/chakra_mcp.git",
    "directory": "sdks/typescript"
  },
  "bugs": {
    "url": "https://github.com/Delta-S-Labs/chakra_mcp/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
