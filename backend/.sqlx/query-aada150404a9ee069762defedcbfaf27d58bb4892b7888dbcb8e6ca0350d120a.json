  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id as user_id, u.email, u.display_name, u.avatar_url, m.role, m.joined_at\n        FROM account_memberships m\n        JOIN users u ON u.id = m.user_id\n        WHERE m.account_id = $1\n        ORDER BY m.joined_at ASC\n        ",
