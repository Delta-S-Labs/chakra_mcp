# ChakraMCP — environment template.
#
# Copy this file to `.env.local` (gitignored) and fill in your values.
# Both .env and .env.local are excluded from git via .gitignore.
#
#   cp .env.example .env.local
#
# Variables marked OPTIONAL can be left as-is; they enable specific
# features (Bedrock support, captcha, etc.) but the relay runs without
# them. Variables marked REQUIRED are needed for the corresponding
# feature to work.

# ─────────────────────────────────────────────────────────────────────
# AI providers — for the example agents under examples/
# ─────────────────────────────────────────────────────────────────────

# NVIDIA NIM — free models at https://build.nvidia.com/
# Get a key: sign in at build.nvidia.com → API tab → Generate.
# OPTIONAL but recommended (free tier, broad model selection).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# AWS Bedrock — for the example agents (Claude on Bedrock, Llama, etc.)
# OPTIONAL. Configure if you want Bedrock-backed example agents.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# OR use a profile from ~/.aws/credentials
# AWS_PROFILE=default

# Anthropic API — direct access (alternative to Bedrock).
# OPTIONAL.
ANTHROPIC_API_KEY=

# OpenAI — alternative provider for the example agents.
# OPTIONAL.
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Relay backend — Rust + Postgres (Phase 1, not yet scaffolded)
# ─────────────────────────────────────────────────────────────────────

# Postgres connection string. The default matches the docker-compose
# Postgres in backend/. REQUIRED when running either backend service.
DATABASE_URL=postgres://chakramcp:chakramcp@localhost:5432/chakramcp

# JWT signing secret — shared between the app and relay services so
# tokens issued by one are accepted by the other.
# Generate with: openssl rand -hex 32
# REQUIRED.
JWT_SECRET=

# Webhook signing secret (HMAC-SHA256). Used by the relay service for
# outbound webhook delivery to agent endpoints.
# REQUIRED for relay (Phase 1.5+).
WEBHOOK_SIGNING_SECRET=

# Email of the bootstrap admin. On sign-in (via the frontend signIn
# callback hitting POST /v1/users/upsert) the user with this email gets
# is_admin = true. Leave unset for no built-in admin.
ADMIN_EMAIL=

# App service port (the user-facing API). Default 8080.
APP_PORT=8080

# Relay service port (Phase 1.5). Default 8090.
RELAY_PORT=8090

# Logging filter. See https://docs.rs/tracing-subscriber/.
RUST_LOG=info,chakramcp_app=debug,chakramcp_relay=debug,sqlx=warn

# ─────────────────────────────────────────────────────────────────────
# Relay web app — frontend auth
# ─────────────────────────────────────────────────────────────────────
# These variables belong in frontend/.env.local (Next.js reads .env
# files from the directory containing next.config.ts, not from the
# repo root). See ./frontend/.env.example for the template.

# ─────────────────────────────────────────────────────────────────────
# Observability (production)
# ─────────────────────────────────────────────────────────────────────

# Sentry DSN for error reporting.
# OPTIONAL.
SENTRY_DSN=

# OpenTelemetry collector endpoint.
# OPTIONAL.
OTEL_EXPORTER_OTLP_ENDPOINT=
